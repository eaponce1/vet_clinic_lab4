<h1 class="mb-4 fw-bold">Vets</h1>

<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th class="text-center">Specialization</th>
      </tr>
    </thead>

    <tbody>
      <% @vets.each do |vet| %>
        <tr>

          <!-- Name -->
          <td>
            <%= link_to "#{vet.first_name} #{vet.last_name}", vet %>
          </td>

          <!-- Email -->
          <td><%= vet.email %></td>

          <!-- Phone -->
          <td><%= vet.phone %></td>

          <!-- Specialization (MEJORADO) -->
          <td class="text-center">
            <span class="badge bg-secondary">
              <%= vet.specialization %>
            </span>
          </td>

        </tr>
      <% end %>
    </tbody>
  </table>
</div>