<h1 class="mb-4 fw-bold">Owners</h1>

<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th class="text-center">Pets</th>
      </tr>
    </thead>

    <tbody>
      <% @owners.each do |owner| %>
        <tr>

          <!-- Name -->
          <td>
            <%= link_to "#{owner.first_name} #{owner.last_name}", owner %>
          </td>

          <!-- Email -->
          <td><%= owner.email %></td>

          <!-- Phone -->
          <td><%= owner.phone %></td>

          <!-- Pets (MEJORADO) -->
          <td class="text-center">
            <span class="badge bg-dark">
              <%= owner.pets.count %>
            </span>
          </td>

        </tr>
      <% end %>
    </tbody>
  </table>
</div>
